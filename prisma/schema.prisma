// GuestOps AI - Prisma schema
// ----------------------------------------------------------------------------
// MVP uses SQLite for zero-config local runs. The schema is written to be
// PostgreSQL-portable:
//   * "enum-like" fields are plain Strings, validated in the app layer (Zod).
//   * JSON payloads are stored as String (JSON.stringify / JSON.parse).
// To move to Postgres: change `provider` to "postgresql", set DATABASE_URL,
// then run `npx prisma migrate dev`. (Optionally promote String enums to
// native enums and *Json fields to the `Json` type.)
// ----------------------------------------------------------------------------

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  plan      String   @default("free") // free | pro | business
  timezone  String   @default("Europe/Istanbul")
  language  String   @default("tr") // default UI/AI language
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users            User[]
  properties       Property[]
  automationRules  AutomationRule[]
  auditLogs        AuditLog[]
  messageTemplates MessageTemplate[]
}

model User {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  email          String   @unique
  passwordHash   String
  role           String   @default("owner") // owner | manager | staff
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assignedTasks Task[]      @relation("TaskAssignee")
  taskUpdates  TaskUpdate[]
  auditLogs    AuditLog[]

  @@index([organizationId])
}

model Property {
  id                   String   @id @default(cuid())
  organizationId       String
  name                 String
  address              String?
  city                 String?
  country              String?
  checkInTime          String   @default("15:00")
  checkOutTime         String   @default("11:00")
  cleaningBufferMinutes Int     @default(120)
  notes                String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  organization     Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  reservations     Reservation[]
  conversations    Conversation[]
  tasks            Task[]
  knowledgeBase    KnowledgeBaseItem[]
  messageTemplates MessageTemplate[]

  @@index([organizationId])
}

model Reservation {
  id              String   @id @default(cuid())
  propertyId      String
  guestName       String
  guestPhone      String?
  guestEmail      String?
  arrivalDate     DateTime
  departureDate   DateTime
  channel         String   @default("manual") // manual | airbnb | booking | direct | other
  status          String   @default("confirmed") // pending | confirmed | cancelled | completed
  totalAmount     Float?
  currency        String   @default("EUR")
  sourceReference String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  property      Property       @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  conversations Conversation[]
  tasks         Task[]

  @@index([propertyId])
  @@index([arrivalDate])
}

model Conversation {
  id              String   @id @default(cuid())
  propertyId      String
  reservationId   String?
  channel         String   @default("manual") // manual | whatsapp | email | airbnb | booking
  guestIdentifier String // name / phone / email used to address the guest
  status          String   @default("new") // new | waiting | answered | problem | closed
  priority        String   @default("standard") // urgent | standard | low
  lastMessageAt   DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  property    Property     @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  reservation Reservation? @relation(fields: [reservationId], references: [id], onDelete: SetNull)
  messages    Message[]

  @@index([propertyId])
  @@index([status])
}

model Message {
  id              String   @id @default(cuid())
  conversationId  String
  direction       String // inbound | outbound
  senderName      String
  body            String
  language        String   @default("tr")
  aiSuggestedReply String?
  aiConfidence    Float?
  aiIntent        String?
  createdAt       DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

model Task {
  id            String   @id @default(cuid())
  propertyId    String
  reservationId String?
  type          String   @default("cleaning") // cleaning | laundry | restock | checkin_prep | checkout_review | maintenance
  title         String
  description   String?
  assignedToId  String?
  dueAt         DateTime?
  status        String   @default("todo") // todo | in_progress | awaiting_review | done
  priority      String   @default("standard") // urgent | standard | low
  checklistJson String? // JSON-encoded array of { label, done }
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  property    Property     @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  reservation Reservation? @relation(fields: [reservationId], references: [id], onDelete: SetNull)
  assignedTo  User?        @relation("TaskAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  updates     TaskUpdate[]

  @@index([propertyId])
  @@index([status])
  @@index([assignedToId])
}

model TaskUpdate {
  id        String   @id @default(cuid())
  taskId    String
  userId    String?
  status    String?
  note      String?
  photoUrl  String?
  createdAt DateTime @default(now())

  task Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([taskId])
}

model KnowledgeBaseItem {
  id         String   @id @default(cuid())
  propertyId String
  category   String   @default("general") // location | checkin | wifi | rules | parking | trash | cleaning | faq | local_tips | general
  title      String
  content    String
  language   String   @default("tr")
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@index([category])
}

model AutomationRule {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  triggerType    String // reservation_created | checkout_completed | message_received | complaint_detected
  conditionJson  String? // JSON-encoded condition
  actionJson     String // JSON-encoded action
  isEnabled      Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model AuditLog {
  id             String   @id @default(cuid())
  organizationId String
  actorUserId    String?
  action         String
  metadataJson   String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actor        User?        @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([organizationId])
}

model MessageTemplate {
  id             String   @id @default(cuid())
  organizationId String
  propertyId     String?  // null = org-wide
  category       String
  title          String
  body           String
  language       String   @default("tr")
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  property     Property?    @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}
