# ----------------------------------------------------------------------------
# Lixus AI - Environment variables
# Copy this file to `.env` and adjust values for your environment.
# ----------------------------------------------------------------------------

# Database -------------------------------------------------------------------
# PostgreSQL connection string. On Railway, add a PostgreSQL database and
# reference its variable (e.g. ${{ Postgres.DATABASE_URL }}).
DATABASE_URL="postgresql://user:password@localhost:5432/lixus?schema=public"

# Auth -----------------------------------------------------------------------
# Used to sign session JWTs. Generate a strong value, e.g.:
#   openssl rand -base64 32
AUTH_SECRET="dev-secret-change-me-please-32-bytes-min"

# Canonical public base URL. Used for anything that leaves our trust boundary
# (email verify links, OAuth redirect_uri) — NEVER the request Host header, which
# is client-controllable (host-header injection). Set to your real domain in prod.
APP_URL="https://www.lixusai.com"

# ENCRYPTION_KEY — used to encrypt secrets at rest (e.g. each customer's own
# Hospitable token). Optional: if empty, AUTH_SECRET is used instead. Keep it
# STABLE in production — changing it makes stored tokens unreadable (re-connect).
#   openssl rand -base64 32
ENCRYPTION_KEY=""

# SUPERADMIN_EMAILS — comma-separated operator emails who can access the Operator
# Panel (/admin): create customer orgs and enter (impersonate) them. Default EMPTY
# = nobody is a super-admin (panel inaccessible). Set this to YOUR login email.
SUPERADMIN_EMAILS=""

# AI Layer (optional) --------------------------------------------------------
# If OPENAI_API_KEY is empty, the app uses a deterministic template-based
# fallback so reply suggestions still work without any external API.
# OPENAI_MODEL = main guest replies (production: gpt-5.1).
# OPENAI_TRANSLATE_MODEL / OPENAI_STYLE_MODEL = optional overrides (fall back to OPENAI_MODEL).
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-5.1"
OPENAI_TRANSLATE_MODEL=""
OPENAI_STYLE_MODEL=""

# Prep-plan AI summary (OPTIONAL, cosmetic) ----------------------------------
# Powers the "AI özeti oluştur" button on /hazirlik — a short natural-language
# gloss of the deterministic shopping/prep list. Any OpenAI-COMPATIBLE endpoint
# works (e.g. akashML). Unset SUPPLY_AI_API_KEY → the button is hidden and the
# deterministic list stands alone. Only aggregate numbers are sent, never guest PII.
SUPPLY_AI_API_KEY=""
SUPPLY_AI_BASE_URL="https://api.akashml.com/v1"
# akashML's GLM-5.2 slug. If the provider changes the id, set it here.
SUPPLY_AI_MODEL="zai-org/GLM-5.2"

# Email ----------------------------------------------------------------------
# Production path is Resend (preferred). Set RESEND_API_KEY + a verified
# RESEND_FROM address. Alternatively use SMTP (EMAIL_* below). If neither is
# configured, emails are logged to the console (dev only).
RESEND_API_KEY=""
RESEND_FROM="Lixus AI <noreply@lixusai.com>"
EMAIL_FROM="Lixus AI <noreply@lixusai.com>"
EMAIL_HOST=""
EMAIL_PORT="587"
EMAIL_USER=""
EMAIL_PASS=""

# Hospitable Public API v2 (Airbnb / Booking.com messaging) -----------------
# Hospitable unifies your channels (Airbnb, Booking, direct) and exposes guest
# messaging via an API. We use it to pull guest messages into the inbox and send
# replies back to the guest on their original channel.
# Docs: https://developer.hospitable.com/docs/public-api-docs
#
# MULTI-TENANT: each organization now connects its OWN Hospitable account from
# Settings (token stored encrypted per-org). HOSPITABLE_API_TOKEN below is only a
# FALLBACK for the founder's original ("primary") org so the original setup keeps
# working; new customer orgs must connect their own. The primary org is ONLY
# the one named by PRIMARY_ORG_ID. In production there is NO fallback (unset ⇒
# the env token is used by nobody); the oldest-org fallback exists in dev/demo only.
#
# HOSPITABLE_API_TOKEN — Personal Access Token (Hospitable → Settings → API).
#                        Leave empty once every org has connected its own.
# HOSPITABLE_API_BASE_URL — optional override (defaults to production v2).
# PRIMARY_ORG_ID — optional: explicit org id allowed to use the env token above.
HOSPITABLE_API_TOKEN=""
HOSPITABLE_API_BASE_URL=""
PRIMARY_ORG_ID=""

# Hospitable OAuth vendor flow — one-click "Hospitable ile Bağlan" (Settings).
# DORMANT unless client id+secret are set: the manual Personal Access Token
# flow above keeps working unconditionally either way.
# HOSPITABLE_OAUTH_CLIENT_ID / _SECRET — REQUIRED. From the Hospitable Partner
#   Portal (partners.hospitable.com → Settings → API → Clients → New client).
# HOSPITABLE_OAUTH_AUTHORIZE_URL / _TOKEN_URL — optional overrides. Default to
#   Hospitable's documented OAuth2 endpoints (auth.hospitable.com/oauth/...);
#   only set these if Hospitable ever changes them.
# HOSPITABLE_OAUTH_REDIRECT_URI — optional override; must exactly match what's
#   registered on the client in the Partner Portal. Defaults to the production
#   callback URL below.
HOSPITABLE_OAUTH_CLIENT_ID=""
HOSPITABLE_OAUTH_CLIENT_SECRET=""
HOSPITABLE_OAUTH_AUTHORIZE_URL=""
HOSPITABLE_OAUTH_TOKEN_URL=""
HOSPITABLE_OAUTH_REDIRECT_URI=""

# Scheduled sync (production 24/7) -------------------------------------------
# Secret that protects the scheduled sync + night auto-reply endpoint
# (/api/cron/sync). Your hosting scheduler must send this value as either
# "Authorization: Bearer <secret>" or an "x-cron-secret" header. A ?secret=
# query param is deliberately NOT accepted (it would leak into request logs).
# Generate one with: openssl rand -base64 32
# Leave empty in local dev to keep the endpoint disabled (returns 401).
CRON_SECRET=""

# Alerts & monitoring --------------------------------------------------------
# Where complaint/refund alerts are emailed (needs SMTP configured above).
ALERT_EMAIL=""
# Where system error reports are emailed (falls back to ALERT_EMAIL if unset).
ERROR_ALERT_EMAIL=""
# Optional Sentry DSN. When set, system errors are also sent to Sentry
# (dependency-free, via the ingest envelope API). Leave empty to disable.
SENTRY_DSN=""

# Disable the in-process 2-minute scheduler if you rely only on external cron.
INTERNAL_CRON_DISABLED=""

# KVKK retention (months). Set (e.g. 24) to anonymize guest PII on stays older
# than N months during deep syncs. EMPTY = retention sweep OFF. Prod: 24.
DATA_RETENTION_MONTHS=""
# Marketing-lead retention (months). EMPTY = never purged.
LEAD_RETENTION_MONTHS=""
# Reverse-trial reminder e-mails ("ending soon"/"ended"). 1 = enabled (prod: 1).
TRIAL_EMAILS_ENABLED=""
TRIAL_REMINDER_DAYS=""
# Sync window tuning (days). Defaults: 90/120 frequent, 540/540 deep, deep hourly.
HOSPITABLE_SYNC_BACK_DAYS=""
HOSPITABLE_SYNC_FORWARD_DAYS=""
HOSPITABLE_DEEP_BACK_DAYS=""
HOSPITABLE_DEEP_FORWARD_DAYS=""
HOSPITABLE_DEEP_EVERY_MIN=""
# Base URL used in e-mail links (default https://www.lixusai.com).
APP_BASE_URL=""
# Hours the AI stays silent after a guest asks for a human (org setting wins).
HUMAN_HANDOFF_HOLD_HOURS=""
# Set 0 to globally strip the "(otomatik hazırlandı)" note from auto-replies.
AUTO_REPLY_DISCLOSURE=""
# Dunning grace days for past_due subscriptions (default 14).
BILLING_PAST_DUE_GRACE_DAYS=""
# Set 1 ONLY when the origin is locked behind Cloudflare: trusts the
# cf-connecting-ip header for rate limiting. Default off = rightmost XFF hop.
TRUST_CF_HEADER=""

# Feature flags --------------------------------------------------------------
# REGISTRATION_OPEN=1 → public self-serve /register is enabled.
# AUTO_REPLY_ENABLED=1 → master switch for automatic guest replies.
# GUEST_CHAT_ENABLED=1 → global kill-switch for the QR guest concierge.
# LANDING_DEMO_ENABLED=1 → public "try the AI" demo on the landing page
#   (unauthenticated OpenAI spend → per-IP rate limit + LANDING_DEMO_DAILY_CAP
#   global daily ceiling, default 300). Off by default.
REGISTRATION_OPEN=""
AUTO_REPLY_ENABLED=""
GUEST_CHAT_ENABLED=""
LANDING_DEMO_ENABLED=""
LANDING_DEMO_DAILY_CAP=""

# Billing / Payments (Faz 2 — DORMANT until configured) ----------------------
# Iyzico (Türkiye). Leave empty to keep ALL billing code dormant. Sandbox keys
# from the Iyzico merchant panel let us build & test before going live.
IYZICO_API_KEY=""
IYZICO_SECRET_KEY=""
# Defaults to the sandbox endpoint when empty. Live: https://api.iyzipay.com
IYZICO_BASE_URL=""
# Shared secret guarding /api/webhooks/iyzico. Empty = endpoint disabled
# (returns 200, stores nothing) so it can't be abused before launch.
IYZICO_WEBHOOK_SECRET=""
# Paddle Billing (Merchant of Record — used when the seller is the Italian
# Partita IVA entity; Paddle collects/remits VAT so no per-country tax reg).
# Leave empty to keep the Paddle code dormant. PADDLE_ENV: sandbox | production.
PADDLE_API_KEY=""
PADDLE_ENV=""
# Signing secret of the Paddle notification destination. Empty = /api/webhooks/
# paddle disabled (returns 200, stores nothing) until billing goes live.
PADDLE_WEBHOOK_SECRET=""
# Paddle PRICE ids (pri_...) for each tier — maps webhook items → plan code.
PADDLE_PRICE_BASLANGIC=""
PADDLE_PRICE_PRO=""
PADDLE_PRICE_ISLETME=""
# Paddle.js (client-side checkout overlay). Client token + env (sandbox|production).
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=""
NEXT_PUBLIC_PADDLE_ENV=""
# Master switch for paywall ENFORCEMENT. Empty/false = nothing is EVER blocked
# (existing customers safe). Set "true" ONLY after backfilling existing orgs as
# active. See ROADMAP.md Faz 2. When "true": expired reverse-trials + lapsed
# subscriptions see the upgrade screen instead of the app (operators bypass).
BILLING_ENFORCED=""
# Reverse-trial length in days (default 14). New signups get full Pro free for
# this long with no card; if not upgraded, access pauses ONLY when enforced.
TRIAL_DAYS=""

# Landing page (optional) ----------------------------------------------------
# WhatsApp business number (digits only, e.g. 905xxxxxxxxx) → shows a WhatsApp
# button. Demo video must be an EMBED url (youtube.com/embed/.. or Loom embed).
NEXT_PUBLIC_WHATSAPP=""
NEXT_PUBLIC_DEMO_VIDEO=""

# App ------------------------------------------------------------------------
NODE_ENV="development"
