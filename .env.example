# ----------------------------------------------------------------------------
# GuestOps AI - Environment variables
# Copy this file to `.env` and adjust values for your environment.
# ----------------------------------------------------------------------------

# Database -------------------------------------------------------------------
# PostgreSQL connection string. On Railway, add a PostgreSQL database and
# reference its variable (e.g. ${{ Postgres.DATABASE_URL }}).
DATABASE_URL="postgresql://user:password@localhost:5432/guestops?schema=public"

# Auth -----------------------------------------------------------------------
# Used to sign session JWTs. Generate a strong value, e.g.:
#   openssl rand -base64 32
AUTH_SECRET="dev-secret-change-me-please-32-bytes-min"

# ENCRYPTION_KEY — used to encrypt secrets at rest (e.g. each customer's own
# Hospitable token). Optional: if empty, AUTH_SECRET is used instead. Keep it
# STABLE in production — changing it makes stored tokens unreadable (re-connect).
#   openssl rand -base64 32
ENCRYPTION_KEY=""

# SUPERADMIN_EMAILS — comma-separated operator emails who can access the Operator
# Panel (/admin): create customer orgs and enter (impersonate) them. Default EMPTY
# = nobody is a super-admin (panel inaccessible). Set this to YOUR login email.
SUPERADMIN_EMAILS=""

# AI Layer (optional) --------------------------------------------------------
# If OPENAI_API_KEY is empty, the app uses a deterministic template-based
# fallback so reply suggestions still work without any external API.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# Email (Nodemailer SMTP) ----------------------------------------------------
# Leave EMAIL_HOST empty to use console logging in development (no SMTP needed).
# For production, configure your SMTP provider (e.g. Mailgun, SendGrid, Postfix).
EMAIL_FROM="GuestOps AI <noreply@guestops.ai>"
EMAIL_HOST=""
EMAIL_PORT="587"
EMAIL_USER=""
EMAIL_PASS=""

# Hospitable Public API v2 (Airbnb / Booking.com messaging) -----------------
# Hospitable unifies your channels (Airbnb, Booking, direct) and exposes guest
# messaging via an API. We use it to pull guest messages into the inbox and send
# replies back to the guest on their original channel.
# Docs: https://developer.hospitable.com/docs/public-api-docs
#
# MULTI-TENANT: each organization now connects its OWN Hospitable account from
# Settings (token stored encrypted per-org). HOSPITABLE_API_TOKEN below is only a
# FALLBACK for the founder's original ("primary") org so the original setup keeps
# working; new customer orgs must connect their own. The primary org is the one
# named by PRIMARY_ORG_ID, or — if unset — the OLDEST org.
#
# HOSPITABLE_API_TOKEN — Personal Access Token (Hospitable → Settings → API).
#                        Leave empty once every org has connected its own.
# HOSPITABLE_API_BASE_URL — optional override (defaults to production v2).
# PRIMARY_ORG_ID — optional: explicit org id allowed to use the env token above.
HOSPITABLE_API_TOKEN=""
HOSPITABLE_API_BASE_URL=""
PRIMARY_ORG_ID=""

# Scheduled sync (production 24/7) -------------------------------------------
# Secret that protects the scheduled sync + night auto-reply endpoint
# (/api/cron/sync). Your hosting scheduler must send this value as either
# "Authorization: Bearer <secret>", an "x-cron-secret" header, or "?secret=".
# Generate one with: openssl rand -base64 32
# Leave empty in local dev to keep the endpoint disabled (returns 401).
CRON_SECRET=""

# Alerts & monitoring --------------------------------------------------------
# Where complaint/refund alerts are emailed (needs SMTP configured above).
ALERT_EMAIL=""
# Where system error reports are emailed (falls back to ALERT_EMAIL if unset).
ERROR_ALERT_EMAIL=""
# Optional Sentry DSN. When set, system errors are also sent to Sentry
# (dependency-free, via the ingest envelope API). Leave empty to disable.
SENTRY_DSN=""

# AI models (optional overrides; all default to gpt-4.1) ----------------------
# OPENAI_MODEL — main guest replies. OPENAI_TRANSLATE_MODEL — translation.
# OPENAI_STYLE_MODEL — host style/answer learning.
OPENAI_MODEL=""

# Disable the in-process 2-minute scheduler if you rely only on external cron.
INTERNAL_CRON_DISABLED=""

# Billing / Payments (Faz 2 — DORMANT until configured) ----------------------
# Iyzico (Türkiye). Leave empty to keep ALL billing code dormant. Sandbox keys
# from the Iyzico merchant panel let us build & test before going live.
IYZICO_API_KEY=""
IYZICO_SECRET_KEY=""
# Defaults to the sandbox endpoint when empty. Live: https://api.iyzipay.com
IYZICO_BASE_URL=""
# Shared secret guarding /api/webhooks/iyzico. Empty = endpoint disabled
# (returns 200, stores nothing) so it can't be abused before launch.
IYZICO_WEBHOOK_SECRET=""
# Paddle Billing (Merchant of Record — used when the seller is the Italian
# Partita IVA entity; Paddle collects/remits VAT so no per-country tax reg).
# Leave empty to keep the Paddle code dormant. PADDLE_ENV: sandbox | production.
PADDLE_API_KEY=""
PADDLE_ENV=""
# Signing secret of the Paddle notification destination. Empty = /api/webhooks/
# paddle disabled (returns 200, stores nothing) until billing goes live.
PADDLE_WEBHOOK_SECRET=""
# Paddle PRICE ids (pri_...) for each tier — maps webhook items → plan code.
PADDLE_PRICE_BASLANGIC=""
PADDLE_PRICE_PRO=""
PADDLE_PRICE_ISLETME=""
# Master switch for paywall ENFORCEMENT. Empty/false = nothing is EVER blocked
# (existing customers safe). Set "true" ONLY after backfilling existing orgs as
# active. See ROADMAP.md Faz 2.
BILLING_ENFORCED=""

# Landing page (optional) ----------------------------------------------------
# WhatsApp business number (digits only, e.g. 905xxxxxxxxx) → shows a WhatsApp
# button. Demo video must be an EMBED url (youtube.com/embed/.. or Loom embed).
NEXT_PUBLIC_WHATSAPP=""
NEXT_PUBLIC_DEMO_VIDEO=""

# App ------------------------------------------------------------------------
NODE_ENV="development"
