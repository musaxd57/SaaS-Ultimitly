# ----------------------------------------------------------------------------
# GuestOps AI - Environment variables
# Copy this file to `.env` and adjust values for your environment.
# ----------------------------------------------------------------------------

# Database -------------------------------------------------------------------
# MVP default: SQLite (zero-config, runs anywhere).
DATABASE_URL="file:./dev.db"
#
# Production: switch prisma/schema.prisma `provider` to "postgresql" and use:
# DATABASE_URL="postgresql://user:password@localhost:5432/guestops?schema=public"

# Auth -----------------------------------------------------------------------
# Used to sign session JWTs. Generate a strong value, e.g.:
#   openssl rand -base64 32
AUTH_SECRET="dev-secret-change-me-please-32-bytes-min"

# AI Layer (optional) --------------------------------------------------------
# If OPENAI_API_KEY is empty, the app uses a deterministic template-based
# fallback so reply suggestions still work without any external API.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# Email (Nodemailer SMTP) ----------------------------------------------------
# Leave EMAIL_HOST empty to use console logging in development (no SMTP needed).
# For production, configure your SMTP provider (e.g. Mailgun, SendGrid, Postfix).
EMAIL_FROM="GuestOps AI <noreply@guestops.ai>"
EMAIL_HOST=""
EMAIL_PORT="587"
EMAIL_USER=""
EMAIL_PASS=""

# WhatsApp Business Cloud API (Meta) ----------------------------------------
# Official API — requires a Meta Business account + WhatsApp Business App.
# Docs: https://developers.facebook.com/docs/whatsapp/cloud-api/get-started
#
# WHATSAPP_TOKEN          — System user permanent access token
# WHATSAPP_PHONE_NUMBER_ID — Numeric ID of your registered WA phone number
# WHATSAPP_VERIFY_TOKEN   — A secret string you choose; enter it in Meta's dashboard
#                           when registering the webhook URL.
# Webhook URL to register in Meta dashboard:
#   https://<your-domain>/api/webhooks/whatsapp
#
# Leave all three empty to run without WhatsApp (replies are console-logged in dev).
WHATSAPP_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_VERIFY_TOKEN=""

# App ------------------------------------------------------------------------
NODE_ENV="development"
