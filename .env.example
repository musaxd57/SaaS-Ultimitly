DATABASE_URL="postgresql://postgres:postgres@localhost:5432/lixus_ai"

# Optional. If empty, the agent system uses deterministic local fallbacks for development.
LITELLM_API_BASE="http://localhost:4000"
LITELLM_API_KEY=""

# LiteLLM model aliases. Keep app code stable by changing real providers in LiteLLM config.
LIXUS_MODEL_MESSAGE_TRIAGE="message_triage"
LIXUS_MODEL_TASK_EXTRACTOR="task_extractor"
LIXUS_MODEL_GUEST_REPLY_DRAFT="guest_reply_draft"
LIXUS_MODEL_RISK_REVIEW="risk_review"
LIXUS_MODEL_REPORT_WRITER="report_writer"
