{
  "name": "lixus-ai-agent-system",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "guard": "node scripts/branch-guard.mjs",
    "dev": "npm run guard && next dev",
    "build": "npm run guard && prisma generate && next build",
    "start": "npm run guard && next start",
    "typecheck": "npm run guard && prisma generate && tsc --noEmit",
    "test": "npm run guard && prisma generate && vitest run",
    "test:watch": "npm run guard && vitest",
    "db:generate": "npm run guard && prisma generate",
    "db:push": "npm run guard && prisma db push"
  },
  "dependencies": {
    "@prisma/client": "^6.2.1",
    "next": "^15.1.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.4",
    "@types/react-dom": "^19.0.2",
    "prisma": "^6.2.1",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
