{
  "name": "guestops-ai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "verify:env": "node scripts/verify-env.mjs",
    "prestart": "node scripts/verify-env.mjs",
    "start": "next start",
    "test": "prisma generate && vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "db:push": "node scripts/guard-local-db.mjs && prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:reset": "node scripts/guard-local-db.mjs && prisma db push --force-reset && tsx prisma/seed.ts",
    "env:recover": "git fetch origin && git reset --hard origin/claude/great-edison-3zqpZ && npx prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.111.0",
    "@hookform/resolvers": "3.9.1",
    "@prisma/client": "6.2.1",
    "bcryptjs": "2.4.3",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "date-fns": "4.1.0",
    "jose": "5.9.6",
    "lucide-react": "0.469.0",
    "next": "^15.5.19",
    "nodemailer": "^8.0.11",
    "prisma": "6.2.1",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "7.54.2",
    "tailwind-merge": "2.6.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "2.4.6",
    "@types/node": "^22.19.20",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.5",
    "eslint-config-next": "^15.5.20",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.15",
    "tailwindcss": "3.4.17",
    "tsx": "^4.22.4",
    "typescript": "5.7.3",
    "vitest": "^2.1.9"
  }
}
